# Скопировать на сервер как .env (рядом с manage.py)
# НЕ коммитить в git

DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=замените-на-случайную-строку-50-символов
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.ru,www.example.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.ru,https://www.example.ru

USE_SQLITE=False
DB_NAME=u123456_dbname
DB_USER=u123456_user
DB_PASSWORD=пароль_из_панели
DB_HOST=localhost
DB_PORT=3306

SITE_URL=https://example.ru
SITE_NAME=Название сайта
